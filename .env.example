# Скопируй в .env и заполни. Сам .env в git НЕ коммитится (см. .gitignore).

# --- База данных ---
POSTGRES_DB=furniture
POSTGRES_USER=furniture
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://furniture:change_me@localhost:5432/furniture
TEST_DATABASE_URL=postgresql+psycopg://furniture:change_me@localhost:5432/furniture_test

# --- Telegram ---
# Токен бота сотрудников от @BotFather. ДЕРЖАТЬ В СЕКРЕТЕ, в код не вписывать.
BOT_TOKEN=0000000000:replace_with_real_token
# Токен отдельного клиентского бота (только просмотр статуса заказа).
CLIENT_BOT_TOKEN=0000000000:replace_with_client_bot_token
# Публичный HTTPS-URL Mini App (домен сервера).
# Прописывается в BotFather как URL кнопки меню.
MINIAPP_URL=https://cnc.factorymanagement.uz

# --- Файловое хранилище ---
# Корень локального хранилища файлов заказов.
STORAGE_ROOT=/opt/cnc_mebel_bot/storage

# --- Часовой пояс предприятия ---
# Используется для определения work_date по времени прихода.
SHOP_TZ=Asia/Tashkent

# --- CORS ---
# Разрешённые origin'ы для Mini App (через запятую).
CORS_ORIGINS=https://cnc.factorymanagement.uz
