[Unit]
Description=CNC Mebel — Client Bot
After=network.target postgresql.service

[Service]
Type=simple
User=deployer
WorkingDirectory=/opt/cnc_mebel_bot/server
EnvironmentFile=/opt/cnc_mebel_bot/.env
ExecStart=/opt/cnc_mebel_bot/venv/bin/python -m bot.client_bot
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
